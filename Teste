	-- Botão Focar
	local FocusBtn = Instance.new("TextButton")
	FocusBtn.Size = UDim2.new(0, 50, 0, 24)
	FocusBtn.Position = UDim2.new(1, -168, 0.5, -12)
	FocusBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 180)
	FocusBtn.BorderSizePixel = 0
	FocusBtn.Text = "📍 IR"
	FocusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	FocusBtn.TextSize = 10
	FocusBtn.Font = Enum.Font.GothamBold
	FocusBtn.ZIndex = 9
	FocusBtn.Parent = Card

	local FocusCorner = Instance.new("UICorner")
	FocusCorner.CornerRadius = UDim.new(0, 5)
	FocusCorner.Parent = FocusBtn

	-- Botão Clonar
	local CloneBtn = Instance.new("TextButton")
	CloneBtn.Size = UDim2.new(0, 58, 0, 24)
	CloneBtn.Position = UDim2.new(1, -112, 0.5, -12)
	CloneBtn.BackgroundColor3 = Color3.fromRGB(228, 105, 11)
	CloneBtn.BorderSizePixel = 0
	CloneBtn.Text = "📋 CLONAR"
	CloneBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	CloneBtn.TextSize = 10
