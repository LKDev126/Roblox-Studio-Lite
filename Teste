	-- Botão Deletar
	local DelBtn = Instance.new("TextButton")
	DelBtn.Size = UDim2.new(0, 46, 0, 24)
	DelBtn.Position = UDim2.new(1, -50, 0.5, -12)
	DelBtn.BackgroundColor3 = Color3.fromRGB(160, 35, 35)
	DelBtn.BorderSizePixel = 0
	DelBtn.Text = "🗑 DEL"
	DelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	DelBtn.TextSize = 10
	DelBtn.Font = Enum.Font.GothamBold
	DelBtn.ZIndex = 9
	DelBtn.Parent = Card

	local DelCorner = Instance.new("UICorner")
	DelCorner.CornerRadius = UDim.new(0, 5)
	DelCorner.Parent = DelBtn

	FocusBtn.MouseEnter:Connect(function()
		TweenService:Create(FocusBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(60, 130, 220)}):Play()
	end)
	FocusBtn.MouseLeave:Connect(function()
		TweenService:Create(FocusBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 100, 180)}):Play()
	end)
	CloneBtn.MouseEnter:Connect(function()
		TweenService:Create(CloneBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 130, 20)}):Play()
	end)
	CloneBtn.MouseLeave:Connect(function()
		TweenService:Create(CloneBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(228, 105, 11)}):Play()
	end)
	DelBtn.MouseEnter:Connect(function()
		TweenService:Create(DelBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(210, 55, 55)}):Play()
	end)
	DelBtn.MouseLeave:Connect(function()
		TweenService:Create(DelBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(160, 35, 35)}):Play()
	end)

	FocusBtn.MouseButton1Click:Connect(function()
		local ref = entry.model
		if ref and ref.Parent then
			local cam = workspace.CurrentCamera
			local primary = ref:IsA("Model") and (ref.PrimaryPart or ref:FindFirstChildWhichIsA("BasePart"))
				or (ref:IsA("BasePart") and ref)
			if primary then
				cam.CFrame = CFrame.new(primary.Position + Vector3.new(0, 10, 20), primary.Position)
				setStatus("Focado em: " .. name, Color3.fromRGB(100, 200, 255))
			end
		else
			setStatus("Modelo não encontrado no workspace", Color3.fromRGB(255, 100, 100))
		end
	end)

	CloneBtn.MouseButton1Click:Connect(function()
		local ref = entry.model
		if ref and ref.Parent then
			local clone = ref:Clone()
			if clone:IsA("Model") then
				local primary = clone.PrimaryPart or clone:FindFirstChildWhichIsA("BasePart")
				if primary then
					clone.PrimaryPart = primary
					clone:SetPrimaryPartCFrame(ref:IsA("Model")
						and (ref.PrimaryPart or ref:FindFirstChildWhichIsA("BasePart")).CFrame * CFrame.new(5, 0, 5)
						or ref.CFrame * CFrame.new(5, 0, 5))
				end
			elseif clone:IsA("BasePart") then
				clone.CFrame = ref.CFrame * CFrame.new(5, 0, 5)
			end
			clone.Parent = workspace
			addModelCard(name .. " (cópia)", clone, assetId)
			setStatus("Clonado: " .. name, Color3.fromRGB(228, 105, 11))
		else
			setStatus("Modelo não encontrado", Color3.fromRGB(255, 100, 100))
		end
	end)

	DelBtn.MouseButton1Click:Connect(function()
		local ref = entry.model
		if ref and ref.Parent then
			ref:Destroy()
			setStatus("Deletado: " .. name, Color3.fromRGB(255, 100, 100))
		end
		TweenService:Create(Card, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
		task.delay(0.16, function() Card:Destroy() end)
	end)

	table.insert(insertedModels, entry)
end

-- =====================
-- LOGICA DE INSERIR MODELO
-- =====================
local function insertModel()
	local rawText = IDInput.Text:match("%d+")
	if not rawText then
		setStatus("ID inválido! Digite apenas números.", Color3.fromRGB(255, 80, 80))
		TweenService:Create(IDInputStroke, TweenInfo.new(0.1), {Color = Color3.fromRGB(255, 80, 80)}):Play()
		task.delay(1.2, function()
			TweenService:Create(IDInputStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 60, 60)}):Play()
		end)
		return
	end

	local assetId = tonumber(rawText)
	GetBtn.Text = "⏳ Carregando..."
	GetBtn.Active = false
	setStatus("Carregando ID: " .. assetId .. "...", Color3.fromRGB(228, 105, 11))

	task.spawn(function()
		local obj = nil
		local modelName = "Model_" .. assetId

		-- Tentativa 1: game:GetObjects
		local ok1, res1 = pcall(function()
			local objs = game:GetObjects("rbxassetid://" .. assetId)
			if objs and #objs > 0 then return objs[1] end
		end)
		if ok1 and res1 then obj = res1 end

		-- Tentativa 2: InsertService
		if not obj then
			local ok2, res2 = pcall(function()
				local model = InsertService:LoadAsset(assetId)
				local children = model:GetChildren()
				if #children > 0 then
					local o = children[1]
					model:Destroy()
					return o
				end
				model:Destroy()
			end)
			if ok2 and res2 then obj = res2 end
		end

		if obj then
			modelName = obj.Name ~= "" and obj.Name or modelName

			local cam = workspace.CurrentCamera
			local targetCF = cam and (cam.CFrame * CFrame.new(0, 0, -12)) or CFrame.new(0, 5, 0)

			if obj:IsA("BasePart") then
				obj.Anchored = true
				obj.CFrame = targetCF
				obj.Parent = workspace
				addModelCard(modelName, obj, assetId)

			elseif obj:IsA("Model") then
				for _, p in ipairs(obj:GetDescendants()) do
					if p:IsA("BasePart") then p.Anchored = true end
				end
				local primary = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
				if primary then
					obj.PrimaryPart = primary
					obj:SetPrimaryPartCFrame(targetCF)
				end
				obj.Parent = workspace
				addModelCard(modelName, obj, assetId)

			else
				obj.Parent = workspace
				addModelCard(modelName, obj, assetId)
			end

			setStatus("Inserido: " .. modelName, Color3.fromRGB(100, 220, 120))
			IDInput.Text = ""
		else
			setStatus("Erro ao carregar ID: " .. assetId, Color3.fromRGB(255, 80, 80))
			TweenService:Create(IDInputStroke, TweenInfo.new(0.1), {Color = Color3.fromRGB(255, 80, 80)}):Play()
			task.delay(1.5, function()
				TweenService:Create(IDInputStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 60, 60)}):Play()
			end)
		end

		GetBtn.Text = "⬇  GET MODEL"
		GetBtn.Active = true
	end)
end

GetBtn.MouseButton1Click:Connect(insertModel)

IDInput.FocusLost:Connect(function(enterPressed)
	if enterPressed then insertModel() end
end)

-- Limpar tudo
ClearAllBtn.MouseButton1Click:Connect(function()
	local count = 0
	for _, entry in ipairs(insertedModels) do
		if entry.model and entry.model.Parent then
			entry.model:Destroy()
			count += 1
		end
	end
	insertedModels = {}
	for _, child in ipairs(ScrollFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
	setStatus(count .. " modelos removidos", Color3.fromRGB(255, 100, 100))
end)

-- =====================
-- DRAG
-- =====================
local dragging = false
local dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
	end
end)
TitleBar.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		MainFrame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

-- =====================
-- TOGGLE ABRIR/FECHAR
-- =====================
local frameOpen = false

local function toggleFrame()
	frameOpen = not frameOpen
	if frameOpen then
		MainFrame.Visible = true
		MainFrame.Size = UDim2.new(0, 420, 0, 0)
		TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, 420, 0, 340)
		}):Play()
	else
		TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 420, 0, 0)
		}):Play()
		task.delay(0.22, function()
			MainFrame.Visible = false
		end)
	end
end

ToggleBtn.MouseButton1Click:Connect(toggleFrame)

